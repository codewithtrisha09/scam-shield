{
  "manifest_version": 3,
  "name": "ScamShield - Job & Internship Offer Checker",
  "version": "1.0.0",
  "description": "Paste a job/internship offer and get a risk score based on red flags, stipend mismatch, and online reputation.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
