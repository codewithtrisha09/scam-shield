# Copy this file to .env and fill in real values. Never commit .env itself.

# MongoDB connection string. For local dev: mongodb://127.0.0.1:27017/scamshield
# For production, use MongoDB Atlas free tier: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://127.0.0.1:27017/scamshield

# Reddit API (free) - create an app at https://www.reddit.com/prefs/apps
# NOT required right now - utils/redditSearch.js currently uses mock data
# because Reddit's non-commercial API access needs separate approval.
# Fill these in once approved, then swap in utils/redditSearch.live.js
# (see README "Reddit data layer" section).
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret

# Gemini API key (optional, FREE tier - no credit card required) - used as
# a fallback when regex extraction comes up mostly empty on messy real-world
# text. Get one at https://aistudio.google.com/apikey
# If left blank, the app just skips the LLM fallback and uses regex results as-is.
GEMINI_API_KEY=your_gemini_api_key

# Google Custom Search (optional) - used for LinkedIn presence verification.
# https://console.cloud.google.com/apis/credentials + https://programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Server port
PORT=5000
